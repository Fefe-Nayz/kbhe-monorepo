# --- KiCad Ignore ---

# Fichiers temporaires et de verrouillage
*.lck
*.lock
~*.kicad_*
*_autosave*

# Fichiers de sauvegarde (Backups)
*.bak
*.kicad_pcb-bak
*.sch-bak
*-bak
/75he-backups/
**/*-backups/
/production/backups/

# Cache des empreintes (Footprint cache)
fp-info-cache

# Fichiers de configuration locale de l'utilisateur
# (Contient la dernière vue, le zoom, etc. - à ne pas partager)
*.kicad_prl

# Dossiers de sortie (à adapter selon vos noms de dossiers)
# Il est préférable de ne pas versionner les fichiers générés (Gerbers, BOM, etc.)
/gerber/
/plot/
/bom/
/fabrication/
/fabrication_check/
/analysis_exports/
/plots/
/plots_after/
/plots_current/
/tmp/
/production/
/production/*.zip
/75he.step
/75he.stl
/fabrication-toolkit-options.json
*.gbr
*.drl
*.pos
*.ipc
*.rpt
*.csv
*.xml
*.svg
*.dxf
*.pdf

# Datasheets are source documentation for the KiCad projects.
!/Docs/
!/Docs/**
!/Legacy/**/Docs/
!/Legacy/**/Docs/**

# Fichiers Netlist (généralement pas nécessaires si vous avez le schématique)
*.net

# --- Fichiers OS (classique) ---
.DS_Store
Thumbs.db

**/.history/
/.history_trim/
