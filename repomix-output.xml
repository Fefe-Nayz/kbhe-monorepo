  resp->command_id = CMD_SET_KEY_SETTINGS;

  if (req->key_index >= 6) {
    resp->status = HID_RESP_INVALID_PARAM;
    return;
  }

  settings_key_t key;
  key.hid_keycode = req->hid_keycode;
  key.actuation_point_mm = req->actuation_point_mm;
