float getValueFromLUT(int voltage) {
  int index = voltage - LUT_START;

  if (index <= 0) {
    return LUT[0];
  }

  if (index >= LUT_SIZE - 1) {
    return LUT[LUT_SIZE - 1];
  }

  return LUT[index];
}
