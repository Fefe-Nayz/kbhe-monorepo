{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KBHE configurator",
  "version": "0.1.9",
  "identifier": "com.kbhe.configurator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KBHE configurator",
        "visible": false,
        "backgroundColor": "#00000000",
        "transparent": true,
        "windowEffects": {
          "effects": [
            "mica"
          ]
        },
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "backgroundColor": "#09090B",
        "width": 500,
        "height": 300,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
